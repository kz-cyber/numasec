# numasec — Environment Variables Reference
#
# numasec does NOT read a .env file. These variables are passed by the
# MCP host via the "env" block in its server config.
#
# Example:
#   "env": {
#     "NUMASEC_ALLOW_INTERNAL": "1"
#   }

# --- Target restrictions ---
# Allow scanning internal/private IPs (lab environments)
NUMASEC_ALLOW_INTERNAL=0

# --- MCP transport ---
# Override transport: stdio (default) | http
MCP_TRANSPORT=stdio

# --- Rate limiting ---
# Per-session limits
NUMASEC_RATE_PER_MINUTE=60
NUMASEC_RATE_CONCURRENT=5
# Global limits (across all sessions)
NUMASEC_RATE_GLOBAL_PER_MINUTE=120
NUMASEC_RATE_GLOBAL_CONCURRENT=10
